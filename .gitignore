# IRIS license/key files

iris.key
*.lic

# =========================

# Healthcare / PHI safety

# =========================

# Do not commit real patient data, real transcripts, or local exports

data/
exports/
real-data/
private-data/
transcripts/private/
fhir-seed/private/

# Keep synthetic seed data committed, but never real PHI.

# fhir-seed/questionnaires/ is okay if synthetic/template-only.

# fhir-seed/patients/ is okay only if fully synthetic.

